{
  "buildCommand": "",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/engine", "destination": "/engine.html" },
    { "source": "/features", "destination": "/features.html" },
    { "source": "/sources", "destination": "/sources.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/demo", "destination": "/demo.html" },
    { "source": "/compare", "destination": "/compare.html" },
    { "source": "/faq", "destination": "/faq.html" },
    { "source": "/changelog", "destination": "/changelog.html" },
    { "source": "/install", "destination": "/install.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/api", "destination": "/api.html" },
    { "source": "/security", "destination": "/security.html" },
    { "source": "/support", "destination": "/support.html" },
    { "source": "/auth", "destination": "/auth.html" },
    { "source": "/account", "destination": "/account.html" },
    { "source": "/pricing", "destination": "/pricing.html" }
  ],
  "redirects": [
    {
      "source": "/token",
      "destination": "https://antares-extension.vercel.app/token.html",
      "permanent": false,
      "has": [{ "type": "query", "key": "ca" }]
    },
    {
      "source": "/token.html",
      "destination": "https://antares-extension.vercel.app/token.html",
      "permanent": false,
      "has": [{ "type": "query", "key": "ca" }]
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/favicon.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/demo.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/demo",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/pricing",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/account",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/auth",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ]
}
