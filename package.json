{
  "name": "antares-website",
  "version": "1.0.0",
  "description": "Antares — marketing site (static HTML, no build step)",
  "private": true,
  "type": "module",
  "scripts": {
    "audit": "node scripts/audit.mjs",
    "audit:mobile": "node scripts/audit.mjs --viewport=mobile",
    "audit:desktop": "node scripts/audit.mjs --viewport=desktop",
    "audit:prod": "node scripts/audit.mjs --base=https://antaresscan.com",
    "lint": "npm run lint:html && npm run lint:css",
    "lint:html": "htmlhint \"*.html\"",
    "lint:css": "stylelint \"css/**/*.css\"",
    "lint:fix": "stylelint \"css/**/*.css\" --fix",
    "hooks:install": "node scripts/install-hooks.mjs",
    "regen:sitemap": "node scripts/regenerate-sitemap.mjs",
    "regen:changelog": "node scripts/regenerate-changelog.mjs",
    "test": "node scripts/audit.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/COMEALAMAISONGROUPE/antares-website.git"
  },
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/COMEALAMAISONGROUPE/antares-website/issues"
  },
  "homepage": "https://github.com/COMEALAMAISONGROUPE/antares-website#readme",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "htmlhint": "^1.9.2",
    "playwright": "^1.60.0",
    "stylelint": "^16.26.1"
  }
}
